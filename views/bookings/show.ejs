<% layout("layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-md-8 offset-md-2">

    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-success text-white d-flex align-items-center gap-2">
        <i class="fa-solid fa-circle-check fs-4"></i>
        <h4 class="mb-0">Booking Confirmed!</h4>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4 mb-3 mb-md-0">
            <img
              src="<%= booking.listing.image.url %>"
              class="img-fluid rounded"
              alt="<%= booking.listing.title %>"
              style="max-height:200px; width:100%; object-fit:cover;"
            />
          </div>
          <div class="col-md-8">
            <h5 class="fw-bold"><%= booking.listing.title %></h5>
            <p class="text-muted mb-1">
              <i class="fa-solid fa-location-dot"></i>
              <%= booking.listing.location %>, <%= booking.listing.country %>
            </p>

            <hr />

            <div class="row g-2">
              <div class="col-6">
                <div class="p-2 bg-light rounded text-center">
                  <small class="text-muted d-block">Check-in</small>
                  <strong><%= booking.checkIn.toLocaleDateString("en-IN", { day:"numeric", month:"short", year:"numeric" }) %></strong>
                </div>
              </div>
              <div class="col-6">
                <div class="p-2 bg-light rounded text-center">
                  <small class="text-muted d-block">Check-out</small>
                  <strong><%= booking.checkOut.toLocaleDateString("en-IN", { day:"numeric", month:"short", year:"numeric" }) %></strong>
                </div>
              </div>
              <div class="col-6">
                <div class="p-2 bg-light rounded text-center">
                  <small class="text-muted d-block">Guests</small>
                  <strong><%= booking.guests %></strong>
                </div>
              </div>
              <div class="col-6">
                <div class="p-2 bg-light rounded text-center">
                  <small class="text-muted d-block">Nights</small>
                  <strong><%= Math.ceil((booking.checkOut - booking.checkIn) / (1000*60*60*24)) %></strong>
                </div>
              </div>
            </div>

            <hr />

            <div class="d-flex justify-content-between align-items-center">
              <small class="text-muted">&#8377;<%= booking.listing.price.toLocaleString("en-IN") %> / night</small>
              <p class="mb-0 fw-bold fs-5">Total: &#8377;<%= booking.totalPrice.toLocaleString("en-IN") %></p>
            </div>

            <div class="mt-3">
              <span class="badge 
                <%= booking.status === 'confirmed' ? 'bg-success' : booking.status === 'cancelled' ? 'bg-danger' : 'bg-warning text-dark' %>
                fs-6">
                <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
              </span>
              <small class="text-muted ms-2">Booking ID: <%= booking._id %></small>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
      <a href="/bookings" class="btn btn-outline-dark">
        <i class="fa-solid fa-list"></i> My Bookings
      </a>
      <a href="/listings/<%= booking.listing._id %>" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left"></i> Back to Listing
      </a>
      <% if (booking.status !== 'cancelled' && booking.checkIn > new Date()) { %>
      <form method="POST" action="/bookings/<%= booking._id %>/cancel?_method=PATCH"
        onsubmit="return confirm('Are you sure you want to cancel this booking?')">
        <button class="btn btn-outline-danger">
          <i class="fa-solid fa-xmark"></i> Cancel Booking
        </button>
      </form>
      <% } %>
    </div>

  </div>
</div>