<% layout("layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-md-10 offset-md-1">
    <h3 class="mb-4 fw-bold">
      <i class="fa-solid fa-calendar-check me-2"></i>My Trips
    </h3>

    <% if (bookings.length === 0) { %>
      <div class="text-center py-5">
        <i class="fa-solid fa-calendar-xmark fa-4x text-muted mb-3"></i>
        <h5 class="text-muted">No trips booked… yet!</h5>
        <a href="/listings" class="btn btn-dark mt-2">Explore stays</a>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% for (let booking of bookings) { %>
          <% if (booking.listing) { %>
          <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
              <div class="row g-0">
                
                <div class="col-4">
                  <img
                    src="<%= booking.listing.image.url %>"
                    class="img-fluid rounded-start h-100"
                    style="object-fit:cover;"
                  />
                </div>

                <div class="col-8">
                  <div class="card-body p-3">
                    
                    <div class="d-flex justify-content-between">
                      <h6 class="fw-bold"><%= booking.listing.title %></h6>
                      <span class="badge bg-success"><%= booking.status %></span>
                    </div>

                    <p class="small text-muted mb-1">
                      <%= booking.listing.location %>
                    </p>

                    <p class="small mb-1">
                      Check-in: <%= booking.checkIn.toDateString() %>
                    </p>

                    <p class="small mb-1">
                      Check-out: <%= booking.checkOut.toDateString() %>
                    </p>

                    <p class="fw-bold mb-2">
                      ₹<%= booking.totalPrice %>
                    </p>

                    <a href="/bookings/<%= booking._id %>" class="btn btn-sm btn-outline-dark">
                      View
                    </a>

                  </div>
                </div>

              </div>
            </div>
          </div>
          <% } %>
        <% } %>
      </div>
    <% } %>

  </div>
</div>