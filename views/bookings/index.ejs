<% layout("layouts/boilerplate") %>

<div class="row mt-4 mb-3">
  <div class="col-md-10 offset-md-1">
    <h3 class="my-bookings-title">
      <i class="fa-solid fa-calendar-check me-2"></i>My Trips
    </h3>

    <% if (bookings.length === 0) { %>
      <div class="empty-bookings text-center">
        <i class="fa-solid fa-calendar-xmark"></i>
        <h5>No bookings yet</h5>
        <a href="/listings" class="btn btn-dark mt-2">Explore Listings</a>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% for (let booking of bookings) { %>
          <% if (booking.listing) { %>
          <div class="col-md-6">
            <div class="card booking-list-card h-100">
              <div class="row g-0">
                <div class="col-4">
                  <img
                    src="<%= booking.listing.image.url %>"
                    class="img-fluid rounded-start h-100"
                    alt="<%= booking.listing.title %>"
                  />
                </div>
                <div class="col-8">
                  <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start">
                      <h6 class="card-title fw-bold mb-1"><%= booking.listing.title %></h6>
                      <span class="badge 
                        <%= booking.status === 'confirmed' ? 'bg-success' : booking.status === 'cancelled' ? 'bg-danger' : 'bg-warning text-dark' %>">
                        <%= booking.status %>
                      </span>
                    </div>
                    <p class="text-muted small mb-1">
                      <i class="fa-solid fa-location-dot"></i> <%= booking.listing.location %>
                    </p>
                    <p class="small mb-1">
                      <i class="fa-regular fa-calendar"></i>
                      <%= booking.checkIn.toLocaleDateString("en-IN", {day:"numeric", month:"short"}) %>
                      →
                      <%= booking.checkOut.toLocaleDateString("en-IN", {day:"numeric", month:"short", year:"numeric"}) %>
                    </p>
                    <p class="small mb-2">
                      <i class="fa-solid fa-user"></i> <%= booking.guests %> guest(s) &bull;
                      <%= Math.ceil((booking.checkOut - booking.checkIn)/(1000*60*60*24)) %> night(s)
                    </p>
                    <p class="fw-bold mb-2">&#8377;<%= booking.totalPrice.toLocaleString("en-IN") %></p>
                    <div class="d-flex gap-1">
                      <a href="/bookings/<%= booking._id %>" class="btn btn-sm btn-dark">Details</a>
                      <% if (booking.status !== 'cancelled' && booking.checkIn > new Date()) { %>
                      <form method="POST" action="/bookings/<%= booking._id %>/cancel?_method=PATCH"
                        onsubmit="return confirm('Cancel this booking?')">
                        <button class="btn btn-sm btn-outline-danger">Cancel</button>
                      </form>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <% } %>
        <% } %>
      </div>
    <% } %>
  </div>
</div>